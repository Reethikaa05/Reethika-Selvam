{{ 'tisso-global.css' | asset_url | stylesheet_tag }}

{% comment %}
  Section: tv-about
  Purpose: Full editorial About Us page
{% endcomment %}

{%- comment -%} ── ABOUT HERO ───────────────────────────────── {%- endcomment -%}
<div class="tv-about-hero">
  <div class="tv-about-hero__bg" aria-hidden="true"></div>
  <div class="tv-about-hero__content">
    <h1 class="tv-about-hero__heading">
      {{ section.settings.hero_heading | replace: '[em]', '<em>' | replace: '[/em]', '</em>' }}
    </h1>
    <p class="tv-about-hero__body">{{ section.settings.hero_body }}</p>
  </div>
</div>

{%- comment -%} ── STORY SPLIT ──────────────────────────────── {%- endcomment -%}
<div class="tv-editorial">
  <div class="tv-editorial__media">
    {% if section.settings.story_image != blank %}
      <img
        src="{{ section.settings.story_image | image_url: width: 900 }}"
        alt="{{ section.settings.story_heading | escape }}"
        width="900"
        height="900"
        loading="lazy"
      />
    {% else %}
      <img
        src="https://images.unsplash.com/photo-1593030761757-71fae45fa0e7?auto=format&fit=crop&w=900&q=80"
        alt="About Us Story"
        width="900"
        height="900"
        style="width: 100%; height: 100%; object-fit: cover; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);"
        loading="lazy"
      />
    {% endif %}
  </div>
  <div class="tv-editorial__content">
    <p class="tv-editorial__kicker">{{ section.settings.story_kicker }}</p>
    <h2 class="tv-editorial__heading">{{ section.settings.story_heading }}</h2>
    <p class="tv-editorial__body">{{ section.settings.story_body }}</p>
  </div>
</div>

{%- comment -%} ── VALUES GRID ──────────────────────────────── {%- endcomment -%}
<div class="tv-values">
  <h2 class="tv-values__heading">What We Stand For</h2>
  <div class="tv-values__grid">
    {% for block in section.blocks %}
      {% if block.type == 'value' %}
        <div class="tv-value-item" {{ block.shopify_attributes }}>
          <div class="tv-value-item__number">0{{ forloop.index }}</div>
          <h3 class="tv-value-item__title">{{ block.settings.value_title }}</h3>
          <p class="tv-value-item__text">{{ block.settings.value_text }}</p>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

{%- comment -%} ── SECOND EDITORIAL (reversed) ──────────────── {%- endcomment -%}
{% if section.settings.editorial2_image != blank %}
  <div class="tv-editorial tv-editorial--reverse">
    <div class="tv-editorial__media">
      <img
        src="{{ section.settings.editorial2_image | image_url: width: 900 }}"
        alt="{{ section.settings.editorial2_heading | escape }}"
        width="900"
        height="900"
        loading="lazy"
      />
    </div>
    <div class="tv-editorial__content">
      <p class="tv-editorial__kicker">{{ section.settings.editorial2_kicker }}</p>
      <h2 class="tv-editorial__heading">{{ section.settings.editorial2_heading }}</h2>
      <p class="tv-editorial__body">{{ section.settings.editorial2_body }}</p>
      <a href="/collections/all" class="tv-btn tv-btn--primary">
        Shop the Collection <span class="tv-btn__arrow">→</span>
      </a>
    </div>
  </div>
{% endif %}

{%- comment -%} ── NEWSLETTER ───────────────────────────────── {%- endcomment -%}
<div class="tv-newsletter">
  <div class="tv-newsletter__inner">
    <p class="tv-newsletter__kicker">Stay in the Loop</p>
    <h2 class="tv-newsletter__heading">Join Our Community</h2>
    <p class="tv-newsletter__body">Be the first to know about new arrivals, exclusive offers, and behind-the-scenes content.</p>
    {% form 'customer' %}
      <input type="hidden" name="contact[tags]" value="newsletter" />
      <div class="tv-newsletter__form">
        <input type="email" name="contact[email]" class="tv-newsletter__input" placeholder="Enter your email" required />
        <button type="submit" class="tv-newsletter__submit">Join Now</button>
      </div>
    {% endform %}
  </div>
</div>

{% schema %}
{
  "name": "TV About Page",
  "tag": "section",
  "settings": [
    {
      "type": "header", "content": "Hero"
    },
    {
      "type": "textarea",
      "id": "hero_heading",
      "label": "Hero Heading (use [em] and [/em] for italic)",
