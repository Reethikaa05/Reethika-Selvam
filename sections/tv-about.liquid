          "type": "text",
          "id": "value_title",
          "label": "Title",
          "default": "Inclusive Sizing"
        },
        {
          "type": "textarea",
          "id": "value_text",
          "label": "Description",
          "default": "Every style available in XXS to 6XL. Because fashion is for everyone."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "TV About Page",
      "blocks": [
        {
          "type": "value",
          "settings": {
            "value_title": "Inclusive Sizing",
            "value_text": "Every style available in XXS to 6XL. Because fashion is for everyone, full stop."
          }
        },
        {
          "type": "value",
          "settings": {
            "value_title": "Ethical Production",
            "value_text": "All garments are crafted in certified fair-trade facilities with safe, fair working conditions."
          }
        },
        {
          "type": "value",
          "settings": {
            "value_title": "Sustainable Materials",
            "value_text": "We use organic, recycled, and low-impact fabrics wherever possible."
          }
        }
      ]
    }
  ]
}
