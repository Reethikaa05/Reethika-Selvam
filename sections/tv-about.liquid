    },
    {
      "type": "header", "content": "Second Editorial"
    },
    {
      "type": "image_picker",
      "id": "editorial2_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "editorial2_kicker",
      "label": "Kicker",
      "default": "Sustainability"
    },
    {
      "type": "text",
      "id": "editorial2_heading",
      "label": "Heading",
      "default": "Ethical Fashion, Every Step of the Way"
    },
    {
      "type": "textarea",
      "id": "editorial2_body",
      "label": "Body",
      "default": "From organic cotton to recycled packaging, every decision we make is guided by our commitment to the planet. We partner only with certified ethical manufacturers and invest in carbon-neutral shipping for every order."
