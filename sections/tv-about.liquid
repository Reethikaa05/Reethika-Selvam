    {
      "type": "textarea",
      "id": "hero_body",
      "label": "Hero Body",
      "default": "Tisso Vison was born from a simple belief: that style should be accessible, sustainable, and inclusive for all body types and all people."
    },
    {
      "type": "header", "content": "Brand Story"
    },
    {
      "type": "image_picker",
      "id": "story_image",
      "label": "Story Image"
    },
    {
      "type": "text",
      "id": "story_kicker",
      "label": "Kicker",
      "default": "Our Origin"
    },
    {
      "type": "text",
      "id": "story_heading",
      "label": "Heading",
      "default": "Born from a Passion for Inclusive Style"
    },
    {
      "type": "textarea",
      "id": "story_body",
      "label": "Body",
